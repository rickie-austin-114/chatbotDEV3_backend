# Knowledge base path — can be a directory of .xlsx files or a single .xlsx file.
# Relative paths are resolved from the backend directory.
KB_PATH=/FAQ_combined

# Number of candidate documents retrieved by the embedding (FAISS) model before reranking.
EMBED_TOP_K=15

# Number of top documents kept after reranking (passed as context to the LLM).
RERANK_TOP_K=5

# Azure OpenAI credentials
AZURE_ENDPOINT=https://us2-east.openai.azure.com/
AZURE_API_VERSION=2024-12-01-preview
AZURE_API_KEY=4de7d36b5e1a44ab8632b120f55756b2
AZURE_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8014
