# Knowledge base path — can be a directory of .xlsx files or a single .xlsx file.
# Relative paths are resolved from the backend directory.
KB_PATH=/FAQ_combined
LEXICON_JSON_PATH=/FAQ_combined/lexicon/custom_lexicon.json

# Number of candidate documents retrieved by the embedding (FAISS) model before reranking.
EMBED_TOP_K=50

# Number of top documents kept after reranking (passed as context to the LLM).
RERANK_TOP_K=25
# Minimum reranker score (after sigmoid normalisation) to include a document in the LLM context.
# Scores are in [0, 1]: 0.5 = decision boundary (equivalent to raw logit 0), >0.5 = relevant.
# Set higher (e.g. 0.7, 0.9) to be more selective; set to 0.0 to disable filtering entirely.
RERANK_THRESHOLD=0.001

# Max completion tokens for new-API models (gpt-5-mini, o-series).
# Must be large enough to cover reasoning tokens + answer tokens.
MAX_COMPLETION_TOKENS=127999

# Azure OpenAI credentials
AZURE_ENDPOINT=https://us2-east.openai.azure.com
AZURE_API_VERSION=2024-12-01-preview
AZURE_API_KEY=4de7d36b5e1a44ab8632b120f55756b2
AZURE_MODEL=gpt-5-mini


# SQLite persistence
DB_PATH=./data/chat_history.db
# Number of most-recent messages loaded per session (2 messages = 1 turn)
HISTORY_LIMIT=20

# Per-request log files
LOG_DIR=./logs

# Server
HOST=0.0.0.0
PORT=8014
