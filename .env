# Knowledge base path — can be a directory of .xlsx files or a single .xlsx file.
# Relative paths are resolved from the backend directory.
KB_PATH=/FAQ_combined
LEXICON_JSON_PATH=/FAQ_combined/lexicon/custom_lexicon.json

# Number of candidate documents retrieved by the embedding (FAISS) model before reranking.
EMBED_TOP_K=50

# Number of top documents kept after reranking (passed as context to the LLM).
RERANK_TOP_K=25

# Azure OpenAI credentials
AZURE_ENDPOINT=https://4davatar.openai.azure.com
AZURE_API_VERSION=2025-01-01-preview
AZURE_API_KEY=fcd522c971634eba81d3cf2fe55b4382
AZURE_MODEL=gpt-4.1

# SQLite persistence
DB_PATH=./data/chat_history.db
# Number of most-recent messages loaded per session (2 messages = 1 turn)
HISTORY_LIMIT=20

# Per-request log files
LOG_DIR=./logs

# Server
HOST=0.0.0.0
PORT=8014
